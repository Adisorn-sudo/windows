{
  "name": "Linux Mint XFCE",
  "service": "windows",
  "containerEnv": {
    "MANUAL": "Y",
    "VERSION": "https://mirror.freedif.org/LinuxMint/iso/stable/22.3/linuxmint-22.3-xfce-64bit.iso",
    "CPU_CORES": "4",
    "RAM_SIZE": "16G"
  },
  "forwardPorts": [8006],
  "portsAttributes": {
    "8006": {
      "label": "Linux Mint Web",
      "onAutoForward": "notify"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "dockerComposeFile": "codespaces.yml",
  "initializeCommand": "docker system prune -f"
}
